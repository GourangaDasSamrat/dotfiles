  "BFS Template": {
    "prefix": "bfs",
    "body": [
      "use std::collections::VecDeque;",
      "",
      "fn bfs(start: usize, adj: &Vec<Vec<usize>>) -> Vec<i32> {",
      "    let n = adj.len();",
      "    let mut dist = vec![-1; n];",
      "    let mut q = VecDeque::new();",
      "",
      "    dist[start] = 0;",
      "    q.push_back(start);",
      "",
      "    while let Some(u) = q.pop_front() {",
      "        for &v in &adj[u] {",
      "            if dist[v] == -1 {",
      "                dist[v] = dist[u] + 1;",
      "                q.push_back(v);",
      "            }",
      "        }",
      "    }",
      "    dist",
      "}"
    ],
    "description": "BFS template for finding shortest paths"
  },
  "DFS Template": {
    "prefix": "dfs",
    "body": [
      "fn dfs(u: usize, adj: &Vec<Vec<usize>>, visited: &mut Vec<bool>) {",
      "    visited[u] = true;",
      "    for &v in &adj[u] {",
      "        if !visited[v] {",
      "            dfs(v, adj, visited);",
      "        }",
      "    }",
      "}"
    ],
    "description": "DFS template for graph traversal"
  },
