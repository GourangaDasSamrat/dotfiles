    "description": "Calculate LCM using GCD"
  },
  "Modular Exponentiation": {
    "prefix": "modpow",
    "body": [
      "fn mod_pow(mut base: i64, mut exp: i64, modulus: i64) -> i64 {",
      "    if modulus == 1 { return 0; }",
      "    let mut result = 1;",
      "    base %= modulus;",
      "    while exp > 0 {",
      "        if exp % 2 == 1 {",
      "            result = (result * base) % modulus;",
      "        }",
      "        exp >>= 1;",
      "        base = (base * base) % modulus;",
      "    }",
      "    result",
      "}"
    ],
    "description": "Fast modular exponentiation"
  },
  "Prime Check": {
    "prefix": "isprime",
    "body": [
      "fn is_prime(n: i64) -> bool {",
      "    if n < 2 { return false; }",
      "    if n == 2 { return true; }",
      "    if n % 2 == 0 { return false; }",
      "    let mut i = 3;",
      "    while i * i <= n {",
      "        if n % i == 0 { return false; }",
      "        i += 2;",
      "    }",
      "    true",
      "}"
    ],
    "description": "Check if number is prime"
  },
  "Sieve of Eratosthenes": {
    "prefix": "sieve",
    "body": [
      "fn sieve(n: usize) -> Vec<bool> {",
      "    let mut is_prime = vec![true; n + 1];",
      "    is_prime[0] = false;",
      "    is_prime[1] = false;",
      "    for i in 2..=((n as f64).sqrt() as usize) {",
      "        if is_prime[i] {",
      "            for j in ((i * i)..=n).step_by(i) {",
      "                is_prime[j] = false;",
      "            }",
      "        }",
      "    }",
      "    is_prime",
      "}"
    ],
    "description": "Sieve of Eratosthenes for finding all primes up to n"
  },
  "Factorial": {
    "prefix": "factorial",
    "body": [
      "fn factorial(n: i64, modulus: i64) -> i64 {",
      "    let mut result = 1;",
      "    for i in 2..=n {",
      "        result = (result * i) % modulus;",
      "    }",
      "    result",
      "}"
    ],
    "description": "Calculate factorial with modulo"
  },
  "Combination (nCr)": {
    "prefix": "combination",
    "body": [
      "fn combination(n: i64, r: i64, modulus: i64) -> i64 {",
      "    if r > n || r < 0 { return 0; }",
      "    let num = factorial(n, modulus);",
      "    let den = (factorial(r, modulus) * factorial(n - r, modulus)) % modulus;",
      "    (num * mod_pow(den, modulus - 2, modulus)) % modulus",
      "}"
    ],
    "description": "Calculate nCr (requires factorial and mod_pow functions)"
  },
