  "Union-Find Data Structure": {
    "prefix": "unionfind",
    "body": [
      "struct UnionFind {",
      "    parent: Vec<usize>,",
      "    rank: Vec<usize>,",
      "}",
      "",
      "impl UnionFind {",
      "    fn new(n: usize) -> Self {",
      "        UnionFind {",
      "            parent: (0..n).collect(),",
      "            rank: vec![0; n],",
      "        }",
      "    }",
      "",
      "    fn find(&mut self, x: usize) -> usize {",
      "        if self.parent[x] != x {",
      "            self.parent[x] = self.find(self.parent[x]);",
      "        }",
      "        self.parent[x]",
      "    }",
      "",
      "    fn union(&mut self, x: usize, y: usize) {",
      "        let px = self.find(x);",
      "        let py = self.find(y);",
      "        if px == py { return; }",
      "        if self.rank[px] < self.rank[py] {",
      "            self.parent[px] = py;",
      "        } else if self.rank[px] > self.rank[py] {",
      "            self.parent[py] = px;",
      "        } else {",
      "            self.parent[py] = px;",
      "            self.rank[px] += 1;",
      "        }",
      "    }",
      "}"
    ],
    "description": "Union-Find data structure with path compression"
  },
