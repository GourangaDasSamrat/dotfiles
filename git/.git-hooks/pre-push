#!/bin/sh

# Verify if pass is available
if ! command -v pass > /dev/null 2>&1; then
    printf "Error: 'pass' is not installed.\n" > /dev/tty
    exit 1
fi

# Read passphrase directly from pass
GIT_PUSH_PASS=$(pass git/push_pass 2>/dev/null)

if [ -z "$GIT_PUSH_PASS" ]; then
    printf "Error: Could not retrieve passphrase from pass (git/push_pass).\n" > /dev/tty
    exit 1
fi

# Initialize interactive terminal session for secure input
printf "Enter Passphrase: " > /dev/tty
stty -echo < /dev/tty
read -r entered_pass < /dev/tty
stty echo < /dev/tty
printf "\n" > /dev/tty

# Validate passphrase
if [ "$entered_pass" = "$GIT_PUSH_PASS" ]; then
    printf "Verification Successful. Proceeding with push.\n" > /dev/tty
    exit 0
else
    printf "Verification Failed. Remote push operation aborted.\n" > /dev/tty
    exit 1
fi
